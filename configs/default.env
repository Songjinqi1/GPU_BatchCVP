# 默认实验配置（可被环境变量覆盖）

PYTHON_BIN=python3

# 基础参数
N=140
Q=3329
DIST=binomial
DIST_PARAM=3
LATS_PER_DIM=1
INST_PER_LAT=2048
N_GUESS_COORD=6
BETA_PRE=46
N_SLICER_COORD=47
DELTA_SLICER_COORD=0
PARAMS='[(140,6,46)]'

# 校验与基准
VALIDATE_BATCHES=1
VALIDATE_ATOL=1e-8
VALIDATE_RTOL=1e-8
GPU_RUNS=5
CPU_RUNS=3
GPU_WARMUP=1

# 输出前缀（相对于 parent_suite/runs）
RUN_NAME=guess6_default
